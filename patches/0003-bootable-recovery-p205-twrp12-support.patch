+static void ClearSideloadRecoveryCommands() {
+	unlink(SCRIPT_FILE_TMP);
+	unlink("/cache/recovery/openrecoveryscript");
+	unlink("/cache/recovery/command");
+	unlink("/data/cache/recovery/openrecoveryscript");
+	unlink("/data/cache/recovery/command");
+}
+
+static void WaitForSideloadChildExit(pid_t sideload_child_pid) {
+	if (sideload_child_pid <= 0)
+		return;
+
+	int status;
+	const auto deadline = std::chrono::steady_clock::now() + std::chrono::seconds(5);
+	while (std::chrono::steady_clock::now() < deadline) {
+		pid_t wait_result = waitpid(sideload_child_pid, &status, WNOHANG);
+		if (wait_result == sideload_child_pid || (wait_result < 0 && errno == ECHILD))
+			return;
+		if (wait_result < 0) {
+			LOGERR("Error waiting for child sideload process: %s\n", strerror(errno));
+			return;
+		}
+		usleep(100000);
+	}
+
+	LOGERR("Child sideload process did not exit, sending SIGKILL.\n");
+	kill(sideload_child_pid, SIGKILL);
+	waitpid(sideload_child_pid, &status, WNOHANG);
+}
