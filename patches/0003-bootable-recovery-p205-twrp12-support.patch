diff --git a/gui/libguitwrp_defaults.go b/gui/libguitwrp_defaults.go
index b1e114e..4f9ed1b 100644
--- a/gui/libguitwrp_defaults.go
+++ b/gui/libguitwrp_defaults.go
@@ -40,6 +40,43 @@ func printCustomThemeWarning(theme string, location string) {
 	fmt.Printf(customThemeWarning)
 }
 
+func copyLanguage(ctx android.BaseContext, recoveryDir string, language string) {
+	if language == "" {
+		return
+	}
+
+	languageFile := "gui/theme/common/languages/" + language + ".xml"
+	if _, err := os.Stat(recoveryDir + languageFile); err != nil {
+		languageFile = "gui/theme/extra-languages/languages/" + language + ".xml"
+	}
+	copyFile(recoveryDir+languageFile, ctx.Config().Getenv("OUT")+"/recovery/root/twres/languages/"+language+".xml")
+}
+
+func copySelectedLanguages(ctx android.BaseContext, recoveryDir string) {
+	languageDest := ctx.Config().Getenv("OUT") + "/recovery/root/twres/languages"
+	languages := strings.Fields(getMakeVars(ctx, "TW_LANGUAGES"))
+	if len(languages) == 0 {
+		copyDir(recoveryDir+"gui/theme/common/languages/", languageDest)
+		return
+	}
+
+	os.RemoveAll(languageDest)
+	os.MkdirAll(languageDest, os.ModePerm)
+	for _, language := range languages {
+		copyLanguage(ctx, recoveryDir, language)
+	}
+}
+
+func copyExtraLanguageFonts(ctx android.BaseContext, recoveryDir string) {
+	languages := strings.Fields(getMakeVars(ctx, "TW_LANGUAGES"))
+	for _, language := range languages {
+		if language == "zh_CN" || language == "zh_TW" {
+			copyFile(recoveryDir+"gui/theme/extra-languages/fonts/DroidSansFallback.ttf", ctx.Config().Getenv("OUT")+"/recovery/root/twres/fonts/DroidSansFallback.ttf")
+			return
+		}
+	}
+}
+
 func copyThemeResources(ctx android.BaseContext, dirs []string, files []string) {
 	outDir := ctx.Config().Getenv("OUT")
 	twRes := outDir + "/recovery/root/twres/"
@@ -57,8 +94,13 @@ func copyThemeResources(ctx android.BaseContext, dirs []string, files []string)
 		} else {
 			dirToCopy = recoveryDir + dir
 		}
-		copyDir(dirToCopy, destDir)
+		if baseDir == "languages" && strings.HasSuffix(dir, "common/languages/") {
+			copySelectedLanguages(ctx, recoveryDir)
+		} else {
+			copyDir(dirToCopy, destDir)
+		}
 	}
+	copyExtraLanguageFonts(ctx, recoveryDir)
 	for idx, file := range files {
 		_ = idx
 		fileToCopy := recoveryDir + file
